{
  "$schema": "https://mintlify.com/docs.json",
  "name": "calcANTT",
  "logo": {
    "light": "/logos/logo-horizontal-principal.svg",
    "dark": "/logos/logo-horizontal-secundario.svg"
  },
  "description": "Documentação da calcANTT: calcule o frete mínimo da tabela ANTT via API REST ou pela plataforma web.",
  "theme": "almond",
  "colors": {
    "primary": "#2563eb",
    "light": "#60a5fa",
    "dark": "#1d4ed8"
  },
  "navbar": {
    "links": [
      {
        "label": "Site",
        "href": "https://calcantt.com.br"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Acessar plataforma",
      "href": "https://app.calcantt.com.br"
    }
  },
  "navigation": {
    "languages": [
      {
        "language": "pt-BR",
        "default": true,
        "tabs": [
          {
            "tab": "Documentação",
