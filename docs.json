                "pages": [
                  "introduction",
                  "quickstart",
                  "plans"
                ]
              },
              {
                "group": "Usando a Plataforma",
                "pages": [
                  "guides/calculator",
                  "guides/cargo-management",
                  "guides/antt-table",
                  "guides/dashboard"
                ]
              },
              {
                "group": "Integrações",
                "pages": [
                  "integrations/api-keys",
                  "integrations/webhooks",
                  "integrations/marketplace",
                  "integrations/logs"
                ]
              },
              {
                "group": "Conta e Configurações",
                "pages": [
                  "settings/users",
                  "settings/billing",
                  "settings/faq"
                ]
              }
            ]
          },
          {
